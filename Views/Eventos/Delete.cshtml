@model GestaoEventos.Models.Evento

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow border-0 p-4">
            <h4 class="text-danger mb-3"> <i class="fa-solid fa-triangle-exclamation me-2"></i> Excluir Evento? </h4>
            <p>Tem certeza que deseja remover o evento <strong> @Model.Titulo</strong>?</p>
            <div class="alert alert-light border">
                <strong>Data:</strong> @Model.Data.ToShortDateString() <br>
                <strong>Categoria:</strong> @Model.Categoria?.Nome
                <strong>Local:</strong> @Model.Local?.Nome
            </div>
            <p class="text-muted small"> Aviso: Isso pode afetar outras categorias e locais </p>
            <hr/>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger py-2"> Confirmar Exclusão</button>
                    <a asp-action="Index" class="btn btn-link text-muted"> Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>